# Public URL of the Gatsby site
PUBLIC_URL=http://localhost

# Google Analytics id, generated during app creation within an account
GOOGLE_ANALYTICS_TRACKING_ID=UA-123456789-0

# https://github.com/gatsbyjs/gatsby/tree/master/packages/gatsby-plugin-google-analytics#optional-fields
GOOGLE_OPTIMIZE_TRACKING_ID=
GOOGLE_EXPERIMENT_ID=
GOOGLE_OPTIMIZE_VARIATION_ID=
GOOGLE_ANALYTICS_SAMPLE_RATE=100
GOOGLE_ANALYTICS_SITE_SPEED_SAMPLE_RATE=1
GOOGLE_ANALYTICS_COOKIE_DOMAIN=auto
