# Public URL of the Gatsby site
PUBLIC_URL=http://localhost

# AWS region
AWS_REGION=eu-central-1
# IAM access key, revealed only during user creation. Read by the AWS CLI.
AWS_ACCESS_KEY_ID=accesskey
# IAM secret access key, revealed only during IAM user creation. Read by the AWS CLI.
AWS_SECRET_ACCESS_KEY=secretaccesskey
# Bucket name, chosen during bucket creation.
AWS_S3_BUCKET_NAME=unique-bucket-name
