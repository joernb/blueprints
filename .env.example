# Public URL of the Gatsby site
PUBLIC_URL=http://localhost

# Tenant-specific auth domain, created during account creation
AUTH0_DOMAIN=example.auth0.com
# Client id, generated during app creation within a tenant
AUTH0_CLIENTID=example
# A public url to jump back to after authentication, should be s.th. like http://example.com/callback
AUTH0_CALLBACK_URL=https://localhost/callback
# A public url to jump to after logout, should be s.th. like http://example.com
AUTH0_LOGOUT_URL=https://localhost
