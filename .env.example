# Public URL of the Gatsby site
PUBLIC_URL=http://localhost

# Authorization domain (Auth0: Tenant domain)
OAUTH2_DOMAIN=example.auth0.com
# Client id to identify the requesting app
OAUTH2_CLIENTID=example
# A public url to jump back to after authentication, should be s.th. like http://example.com/callback
OAUTH2_REDIRECT_URI=https://localhost/callback
# A public url to jump to after logout, should be s.th. like http://example.com
OAUTH2_LOGOUT_URL=https://localhost
# Space-separated list of requested scopes (permissions)
OAUTH2_SCOPE="openid profile email"
