  "scripts": {
    "format": "prettier --write src/**/*.{js,ts}",
    "start": "nodemon --watch src --exec babel-node -r node_modules/dotenv/config --extensions '.js,.ts' src/index.ts",
    "build": "babel src --out-dir dist --extensions '.js,.ts'",
    "serve": "node -r dotenv/config dist/index.js",
