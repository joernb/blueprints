{
  "name": "TODO-set-node-package-name",
  "private": true,
  "version": "1.0.0",
  "dependencies": {
    "@aws-cdk/aws-apigateway": "^1.18.0",
    "@aws-cdk/aws-lambda": "^1.18.0",
    "@aws-cdk/core": "^1.8.0",
    "aws-serverless-express": "^3.3.6",
    "express": "^4.17.1"
  },
  "devDependencies": {
    "@aws-cdk/assert": "^1.6.1",
    "@babel/cli": "^7.6.4",
    "@babel/core": "^7.6.4",
    "@babel/node": "^7.6.3",
    "@babel/plugin-transform-typescript": "^7.7.4",
    "@babel/preset-env": "^7.6.3",
    "@types/aws-serverless-express": "^3.3.2",
    "@types/express": "^4.17.2",
    "@types/node": "^12.7.2",
    "aws-cdk": "^1.8.0",
    "dotenv": "^8.2.0",
    "dotenv-cli": "^3.1.0",
    "ncp": "^2.0.0",
    "nodemon": "^1.19.4",
    "prettier": "^1.18.2",
    "ts-node": "^8.3.0",
    "tslint": "^5.18.0",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^3.5.3"
  },
  "scripts": {
    "start": "NODE_OPTIONS='-r dotenv/config' nodemon --watch src --exec babel-node --extensions '.js,.ts' src/serve.ts",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx}",
    "build": "yarn babel:build && yarn deps:bundle",
    "babel:build": "babel src --out-dir dist --delete-dir-on-start --extensions '.js,.ts'",
    "deps:bundle": "cp package.json dist/package.json && cd dist && yarn install --production",
    "serve": "NODE_OPTIONS='-r dotenv/config' node dist/serve.js",
    "test": "echo \"TODO: Write test script!\"",
    "lint": "prettier --check src/**/*.{js,jsx,ts,tsx} && tslint -c tslint.json 'src/**/*.{js,jsx,ts,tsx}'",
    "deploy": "yarn cdk:bootstrap && yarn cdk:deploy --require-approval never",
    "cdk:bootstrap": "NODE_OPTIONS='-r dotenv/config' cdk bootstrap",
    "cdk:deploy": "NODE_OPTIONS='-r dotenv/config' cdk deploy",
    "cdk:diff": "NODE_OPTIONS='-r dotenv/config' cdk diff",
    "cdk:destroy": "NODE_OPTIONS='-r dotenv/config' cdk destroy"
  }
}
