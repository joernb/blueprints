  "scripts": {
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx}",
    "build": "echo \"TODO: Write build script!\"",
    "test": "echo \"TODO: Write test script!\"",
    "lint": "prettier --check src/**/*.{js,jsx,ts,tsx} && tslint -c tslint.json 'src/**/*.{js,jsx,ts,tsx}'",
    "deploy": "yarn cdk:bootstrap && yarn cdk:deploy --require-approval never",
